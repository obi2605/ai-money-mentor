# ==============================================================================
# .gitignore — AI Money Mentor
# ==============================================================================

# ── Secrets (NEVER commit these) ──────────────────────────────────────────────
.env
*.key
*.pem

# ── User-uploaded documents (privacy — never commit user PDFs) ────────────────
uploads/
uploads/*
!uploads/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env/

# ── Distribution / packaging ──────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
*~
