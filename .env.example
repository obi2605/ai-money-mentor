# ==============================================================================
# .env.example — Copy this file to .env and fill in your keys
# NEVER commit the actual .env file to git.
# ==============================================================================

# Required: Groq API Key (used by LangChain for intent detection + variable extraction)
GROQ_API_KEY=gsk_...

# Optional: Override log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
